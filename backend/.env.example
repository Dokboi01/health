NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careaxis
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=30m
BCRYPT_SALT_ROUNDS=12
FCM_ENABLED=false
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
REMINDER_DISPATCH_ENABLED=false
REMINDER_DISPATCH_INTERVAL_MS=60000
REMINDER_DISPATCH_BATCH_SIZE=50
