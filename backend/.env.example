NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careaxis
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
